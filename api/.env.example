# Copy to .env and fill in to enable AI-generated quizzes.
# Leave everything blank to use the built-in offline question generator.

# --- Option A: OpenAI (api.openai.com) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Option B: Azure OpenAI / Azure AI Foundry ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01
# AZURE_OPENAI_ENDPOINT auth uses OPENAI_API_KEY above as the API key.

# Server port (optional)
PORT=3001
